# Public site URL, used for metadataBase/OG/sitemap (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yerrmak.pp.ua

# Sanity project connection (see https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# Read token, only required if the dataset is private
SANITY_API_READ_TOKEN=

# Shared secret configured on the Sanity webhook that calls /api/revalidate
SANITY_REVALIDATE_SECRET=
